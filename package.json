{
  "name": "tramlaptopviet-project1",
  "private": true,
  "version": "1.0.0",
  "main": "package.json",
  "license": "UNLICENSED",
  "scripts": {
    "build": "sanity build",
    "deploy": "sanity deploy",
    "deploy-graphql": "sanity graphql deploy",
    "dev": "sanity dev",
    "schema:deploy": "sanity schemas deploy --workspace default",
    "schema:validate": "sanity schemas validate --workspace default",
    "lint": "eslint .",
    "seed": "sanity exec scripts/seed.ts --with-user-token",
    "start": "sanity start",
    "test": "node --test scripts/*.test.mjs",
    "article:validate": "node scripts/publish-article.mjs --dry-run"
  },
  "keywords": [
    "sanity"
  ],
  "dependencies": {
    "@sanity/icons": "^5.1.0",
    "@sanity/vision": "^6.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanity": "^6.5.0",
    "styled-components": "^6.1.18"
  },
  "devDependencies": {
    "@sanity/eslint-config-studio": "^6.0.0",
    "@types/node": "22.19.19",
    "@types/react": "^19.2.14",
    "eslint": "^9.28",
    "prettier": "^3.5",
    "typescript": "^5.8"
  },
  "prettier": {
    "bracketSpacing": false,
    "printWidth": 100,
    "semi": false,
    "singleQuote": true
  }
}
